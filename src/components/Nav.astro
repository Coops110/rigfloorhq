---
export interface Props {
  lang?: 'en' | 'es';
  alternateHref?: string;
}
const { lang = 'en', alternateHref } = Astro.props as Props;

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && href !== '/es' && path.startsWith(href));

const linksEn = [
  { href: '/careers', label: 'Careers' },
  { href: '/equipment', label: 'Equipment' },
  { href: '/drilling', label: 'Drilling' },
  { href: '/calculators', label: 'Calculators' },
  { href: '/welding', label: 'Welding' },
  { href: '/safety', label: 'Safety' },
  { href: '/glossary', label: 'Glossary' },
  { href: '/blog', label: 'Blog' },
];

// Glossary has no Spanish version yet, so it's intentionally excluded from the Spanish nav
// rather than linking out to an English-only page from within a Spanish page.
const linksEs = [
  { href: '/es/careers', label: 'Carreras' },
  { href: '/es/equipment', label: 'Equipo' },
  { href: '/es/drilling', label: 'Perforación' },
  { href: '/es/calculators', label: 'Calculadoras' },
  { href: '/es/welding', label: 'Soldadura' },
  { href: '/es/safety', label: 'Seguridad' },
  { href: '/es/blog', label: 'Blog' },
];

const links = lang === 'es' ? linksEs : linksEn;
const homeHref = lang === 'es' ? '/es' : '/';
const switcherHref = alternateHref ?? (lang === 'es' ? '/' : '/es');
const switcherLabel = lang === 'es' ? 'EN' : 'ES';
---
<nav class="site-nav">
  <a href={homeHref} class="nav-logo"><img src="/logo.svg" alt="RigFloorHQ" class="nav-logo-img" /></a>

  <div class="nav-links-desktop">
    {links.map(link => (
      <a href={link.href} class={`nav-link ${isActive(link.href) ? 'active' : ''}`}>{link.label}</a>
    ))}
    <a href={switcherHref} class="nav-lang-switch" aria-label="Switch language">{switcherLabel}</a>
  </div>

  <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false" id="nav-hamburger">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="nav-mobile-menu" id="nav-mobile-menu">
  {links.map(link => (
    <a href={link.href} class={`nav-mobile-link ${isActive(link.href) ? 'active' : ''}`}>{link.label}</a>
  ))}
  <a href={switcherHref} class="nav-mobile-link nav-lang-switch-mobile">{lang === 'es' ? 'English' : 'Español'}</a>
</div>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const mobileMenu = document.getElementById('nav-mobile-menu');
  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.toggle('open');
      hamburger.classList.toggle('active', isOpen);
      hamburger.setAttribute('aria-expanded', String(isOpen));
    });
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('open');
        hamburger.classList.remove('active');
        hamburger.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
