---
export interface Props {
  lang?: 'en' | 'es';
}
const { lang = 'en' } = Astro.props as Props;
const year = new Date().getFullYear();
---
{lang === 'es' ? (
  <footer class="site-footer">
    <div>
      <div class="footer-logo">RigFloorHQ</div>
      <p class="footer-sub">La referencia completa del campo petrolero y de gas — perforación, soldadura, control de pozos y orientación profesional para todos los niveles de la industria.</p>
    </div>

    <div class="footer-col">
      <h4>Secciones</h4>
      <a href="/es/careers">Carreras</a>
      <a href="/es/equipment">Equipo</a>
      <a href="/es/drilling">Perforación</a>
      <a href="/es/calculators">Calculadoras</a>
    </div>

    <div class="footer-col">
      <h4>Más</h4>
      <a href="/es/welding">Soldadura</a>
      <a href="/es/safety">Seguridad</a>
      <a href="/es/blog">Blog</a>
      <a href="/glossary">Glosario (inglés)</a>
    </div>

    <div class="footer-bottom">
      © {year} RigFloorHQ. Contenido educativo y de referencia únicamente. Siga siempre los procedimientos aprobados por su empresa, los requisitos regulatorios y las instrucciones de su supervisor certificado de control de pozos. Las decisiones de control de pozos nunca deben tomarse basándose únicamente en material de referencia.
    </div>
  </footer>
) : (
  <footer class="site-footer">
    <div>
      <div class="footer-logo">RigFloorHQ</div>
      <p class="footer-sub">The complete oil & gas field reference — drilling, welding, well control, and career guidance for every level of the industry.</p>
    </div>

    <div class="footer-col">
      <h4>Careers</h4>
      <a href="/careers/roughneck">Become a Roughneck</a>
      <a href="/careers/driller">Become a Driller</a>
      <a href="/careers/salary">Salary Guide</a>
      <a href="/careers/certifications">Certifications</a>
    </div>

    <div class="footer-col">
      <h4>Technical</h4>
      <a href="/pillars/advanced-well-control-and-hydrostatics">Advanced Well Control</a>
      <a href="/drilling/mud-weight">Mud Weight & Pressure</a>
      <a href="/drilling/well-control">Well Control</a>
      <a href="/calculators">Calculators</a>
      <a href="/equipment/rig-types">Rig Types</a>
    </div>

    <div class="footer-col">
      <h4>Reference</h4>
      <a href="/welding">Rig Welding</a>
      <a href="/safety">Safety & PPE</a>
      <a href="/glossary">Field Glossary</a>
      <a href="/blog">Blog</a>
      <a href="/es">Español</a>
    </div>

    <div class="footer-bottom">
      © {year} RigFloorHQ. Educational and reference content only. Always follow your company's approved procedures, regulatory requirements, and the instructions of your certified well control supervisor. Well control decisions must never be made solely from reference materials.
    </div>
  </footer>
)}
