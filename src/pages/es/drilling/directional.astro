<BaseLayout
  title="Perforación Direccional Explicada — MWD, LWD y Dirección de la Barrena"
  description="Cómo funciona la perforación direccional: herramientas MWD/LWD, motores de fondo, métodos de dirección, y por qué la perforación horizontal transformó la industria."
  breadcrumbs={[{ label: 'Perforación', href: '/es/drilling' }, { label: 'Perforación Direccional', href: '/es/drilling/directional' }]}
  lang="es"
