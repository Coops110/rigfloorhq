---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const terms = [
  { term: "Annular Preventer", def: "Top element of a BOP stack; a rubber sealing element that closes around pipe of nearly any size or on open hole." },
  { term: "BHA", def: "Bottom Hole Assembly. Everything below the drill collars — bit, stabilizers, MWD tools, motors." },
  { term: "Blind Rams", def: "BOP rams that seal a fully open hole (no pipe present) using flat steel faces." },
  { term: "BOP", def: "Blowout Preventer. High-pressure valve system on the wellhead that seals the well in an emergency." },
  { term: "BOSIET", def: "Basic Offshore Safety Induction & Emergency Training. Mandatory for offshore work, includes HUET." },
  { term: "Choke Line", def: "Piping that allows controlled circulation of fluid out of the well while the BOP is closed." },
  { term: "Company Man", def: "The operating oil company's on-site representative with final authority on well decisions." },
  { term: "Derrickman", def: "Works the monkey board high in the derrick, guiding pipe stands and managing mud systems." },
  { term: "Directional Driller", def: "Specialist who steers the bit along a planned trajectory using MWD tools and downhole motors." },
  { term: "Dogleg Severity (DLS)", def: "Measure of how sharply a wellbore curves, in degrees per 100 ft. Excessive DLS increases torque/drag." },
  { term: "Drawworks", def: "The winch system on the rig that raises and lowers the drill string via the traveling block." },
  { term: "Drill Collar", def: "Heavy thick-walled pipe in the BHA that provides weight on bit (WOB)." },
  { term: "ECD", def: "Equivalent Circulating Density. Effective mud weight while pumping, including annular friction losses — always higher than static mud weight." },
  { term: "Fracture Pressure", def: "The pressure at which a formation cracks and drilling fluid is lost into the rock. Upper limit of the mud weight window." },
  { term: "H2S", def: "Hydrogen sulfide — a toxic, flammable gas found in sour formations. Extremely dangerous even in small concentrations." },
  { term: "HUET", def: "Helicopter Underwater Escape Training. Core component of BOSIET for offshore workers." },
  { term: "HWDP", def: "Heavy Weight Drill Pipe. Thicker-walled transition pipe between drill pipe and drill collars." },
  { term: "ICP", def: "Initial Circulating Pressure. The standpipe pressure held at the start of a kill circulation." },
  { term: "IWCF", def: "International Well Control Forum — issues globally recognized well control certifications, Levels 2-4." },
  { term: "Kelly", def: "The square or hexagonal pipe historically used to transmit rotation from the rotary table to the drill string; largely replaced by top drives on modern rigs." },
  { term: "Kick", def: "An influx of formation fluid into the wellbore, caused by formation pressure exceeding hydrostatic pressure." },
  { term: "Kill Mud Weight (KMW)", def: "The mud weight required to exactly balance formation pressure after a kick — the target weight for well control operations." },
  { term: "Kill Sheet", def: "The calculation worksheet used during well control to document kick data and the pump schedule for killing the well." },
  { term: "LOT", def: "Leak-Off Test. Pumps fluid into the well after each casing shoe to determine fracture gradient." },
  { term: "LWD", def: "Logging While Drilling. Real-time formation evaluation data (resistivity, density, gamma ray) transmitted during drilling." },
  { term: "Monkey Board", def: "The derrick platform, typically 90-100 ft up, where the derrickman works during tripping operations." },
  { term: "Mud Logger", def: "Analyzes drill cuttings and gas shows in real time to identify formation changes and hydrocarbon indications." },
  { term: "MWD", def: "Measurement While Drilling. Downhole tools transmitting directional data to surface via mud pulse telemetry." },
  { term: "OIM", def: "Offshore Installation Manager. Overall command authority for an offshore installation and its personnel." },
  { term: "Overbalance", def: "The margin by which hydrostatic pressure exceeds pore pressure. Typical safe range: 200-500 psi." },
  { term: "PDC Bit", def: "Polycrystalline Diamond Compact bit — synthetic diamond cutters in a shearing action, the dominant bit type today." },
  { term: "Pipe Rams", def: "BOP rams that close around a specific pipe diameter, sealing the annulus while pipe remains in the hole." },
  { term: "POOH / RIH", def: "Pull Out Of Hole / Run In Hole — tripping the drill string to surface or back into the wellbore." },
  { term: "Pore Pressure", def: "The pressure of fluids within reservoir rock pores. Normal gradient roughly 0.433-0.465 psi/ft." },
  { term: "Roughneck", def: "Rig floor crew member who makes up and breaks out pipe connections. Also called a floorhand." },
  { term: "Roustabout", def: "Entry-level general labor position — cleaning, painting, moving equipment. No prior experience required." },
  { term: "ROP", def: "Rate of Penetration. How fast the bit is drilling, in ft/hr. A sudden increase is called a drilling break." },
  { term: "Shear Rams", def: "Emergency BOP rams that cut through drill pipe and seal the well simultaneously." },
  { term: "SICP", def: "Shut-In Casing Pressure. Recorded on the casing side after shutting in on a kick." },
  { term: "SIDPP", def: "Shut-In Drill Pipe Pressure. Directly reflects excess formation pressure above hydrostatic after shut-in." },
  { term: "Toolpusher", def: "Overall supervisor of the drilling contractor's rig operations, managing all crews, tools, and equipment." },
  { term: "Top Drive", def: "Motor system that rotates the drill string, allowing continuous rotation while adding stands — replaced the kelly on most modern rigs." },
  { term: "Trip Gas", def: "Gas entering the wellbore when pulling the string out of hole due to the swab effect. Monitored by the mud logger." },
  { term: "WOB", def: "Weight on Bit. The portion of drill collar weight applied to the bit to create cutting force." },
];
---
<BaseLayout
  title="Oil Rig Glossary — Full A-Z Field Terminology Reference"
  description="Complete glossary of oil rig and drilling terminology, from BHA to WOB. Every term explained in plain language for new hands and experienced crew alike."
  breadcrumbs={[{ label: 'Glossary', href: '/glossary' }]}
>
  <Nav slot="nav" />
  <Footer slot="footer" />

  <div class="page-hero">
    <div class="page-hero-eyebrow">11 — Reference</div>
    <h1>Field <span>Glossary</span></h1>
    <p class="page-hero-sub">Every term used on the rig, in one place. From BHA to WOB — learn these and you'll sound like you've been there.</p>
    <div class="page-meta">
      <span class="page-meta-item"><strong>{terms.length}</strong> terms and counting</span>
    </div>
  </div>

  <section class="block">
    <div class="glossary-grid">
      {terms.map(t => (
        <div class="gloss-item">
          <div class="gloss-term">{t.term}</div>
          <div class="gloss-def">{t.def}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="block">
    <div class="note-box" style="max-width:700px;">
      <strong>Looking for something deeper?</strong> Many of these terms link to full explainer pages elsewhere on the site — see <a href="/drilling/well-control" style="color:var(--amber);">Well Control</a>, <a href="/equipment/bop" style="color:var(--amber);">Blowout Preventers</a>, and <a href="/equipment/drill-string" style="color:var(--amber);">The Drill String</a> for complete technical breakdowns.
    </div>
  </section>
</BaseLayout>
